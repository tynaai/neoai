# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL where this Node.js API is reachable.
BETTER_AUTH_URL=http://localhost:8787
# Browser origin allowed to send credentialed API requests.
CORS_ORIGIN=http://localhost:5173
# Neon pooled PostgreSQL connection string used directly by the Node.js server.
DATABASE_URL=
# OpenAI API key used by the Mastra assistant agent.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://mkp-api.fptcloud.com

# Mastra Observability — create/link a project at https://projects.mastra.ai.
# The same exporter is used by API requests and requests initiated from Studio.
MASTRA_PLATFORM_ACCESS_TOKEN=
MASTRA_PROJECT_ID=
